#!/usr/bin/env bash
# Switch to the next or previous tmux session by creation index
# (matching the order shown in choose-tree)

direction="${1:?Usage: tmux-switch-session <next|prev>}"

sessions=$(tmux list-sessions -F '#{session_id}' | sort -t'$' -k2 -n)
current=$(tmux display-message -p '#{session_id}')

case "$direction" in
  prev)
    prev=""
    for s in $sessions; do
      if [ "$s" = "$current" ] && [ -n "$prev" ]; then
        tmux switch-client -t "$prev"
        exit
      fi
      prev=$s
    done
    ;;
  next)
    found=0
    for s in $sessions; do
      if [ "$found" = 1 ]; then
        tmux switch-client -t "$s"
        exit
      fi
      if [ "$s" = "$current" ]; then
        found=1
      fi
    done
    ;;
esac
