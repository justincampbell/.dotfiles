#!/bin/bash
# Launch a workflow, stream output, and switch to the new session
# Usage: launch-workflow <workflow-name> <url>

set -o pipefail

LOG="/tmp/workflow-launch.log"

# Set up PATH for non-interactive context
export PATH="$HOME/.dotfiles/bin:$HOME/.dotfiles/workflows/tasks:$HOME/.local/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

workflow_name="${1:?Usage: launch-workflow <workflow-name> <url>}"
url="${2:?Usage: launch-workflow <workflow-name> <url>}"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "Starting $workflow_name..."

# Run with --detached, streaming output and logging
"$SCRIPT_DIR/start-workflow" --detached "$workflow_name" "$url" 2>&1 | tee "$LOG"
exit_code=${PIPESTATUS[0]}

if [ $exit_code -eq 0 ]; then
    session_name=$(grep -o 'Started .* workflow in .*' "$LOG" | sed 's/Started .* workflow in //')
    if [ -n "$session_name" ]; then
        echo "Switching to $session_name..."
        tmux switch-client -t "=$session_name" 2>/dev/null || true
    fi
else
    echo ""
    echo "Failed (exit $exit_code). Log: $LOG"
    exit $exit_code
fi
