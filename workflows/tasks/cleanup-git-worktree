#!/bin/bash
# Remove git worktree and associated tmux session

set -euo pipefail

# Source shared utilities
source "$(dirname "$0")/../shared.sh"

# Get worktree directory - default to current directory if not provided
worktree_dir="${1:-$PWD}"

# Resolve to absolute path
if [ -d "$worktree_dir" ]; then
  worktree_dir=$(cd "$worktree_dir" && pwd)
else
  echo "Error: Directory does not exist: $worktree_dir" >&2
  exit 1
fi

# Verify this is a git directory (either .git file or .git directory)
if [ ! -e "$worktree_dir/.git" ]; then
  echo "Error: $worktree_dir is not a git directory" >&2
  exit 1
fi

# Check if this is a worktree or the main repo
# Worktrees have a .git file, main repos have a .git directory
if [ -f "$worktree_dir/.git" ]; then
  # This is a worktree - get the main repository
  git_file_content=$(cat "$worktree_dir/.git")
  # Extract gitdir path from "gitdir: /path/to/.git/worktrees/name"
  base_repo_git_dir=$(echo "$git_file_content" | sed 's/^gitdir: //' | sed 's|/\.git/worktrees/.*||')
  base_repo="$base_repo_git_dir"
  is_worktree=true
else
  # This is the main repository - don't allow cleanup
  echo "Error: Cannot cleanup main repository. This task is only for worktrees." >&2
  exit 1
fi

# Find tmux session by start directory (handles renamed sessions)
session_name=""
while IFS=$'\t' read -r sname spath; do
    if [ "$spath" = "$worktree_dir" ]; then
        session_name="$sname"
        break
    fi
done < <(tmux list-sessions -F '#{session_name}	#{session_path}' 2>/dev/null || true)
if [ -z "$session_name" ]; then
    echo "No tmux session found for directory: $worktree_dir" >&2
fi

# Verify base repo exists
if [ ! -d "$base_repo" ]; then
  echo "Error: Base repository not found at $base_repo" >&2
  exit 1
fi

# Change to base repo for git operations
cd "$base_repo"

# STEP 1: Kill other panes/windows in the session so processes release file handles
# We can't kill the whole session yet — this script may be running inside it
if [ -n "$session_name" ] && tmux has-session -t "=$session_name" 2>/dev/null; then
  echo "Killing other panes in session: $session_name" >&2

  current_pane="${TMUX_PANE:-}"

  if [ -n "$current_pane" ]; then
    # Kill all panes in the session except the one running this script
    for pane_id in $(tmux list-panes -s -t "=$session_name" -F '#{pane_id}' 2>/dev/null); do
      if [ "$pane_id" != "$current_pane" ]; then
        tmux kill-pane -t "$pane_id" 2>/dev/null || true
      fi
    done
  else
    echo "Warning: TMUX_PANE not set, skipping pane cleanup" >&2
  fi

  # Give processes a moment to exit and release file handles
  sleep 1
fi

# STEP 2: Remove git worktree (force removal)
if [ -d "$worktree_dir" ]; then
  echo "Removing worktree directory: $worktree_dir" >&2

  if err=$(git worktree remove --force "$worktree_dir" 2>&1); then
    echo "Successfully removed worktree: $worktree_dir" >&2
  else
    echo "Warning: git worktree remove failed: $err" >&2
    # Clean untracked files/dirs that cause "Directory not empty"
    git -C "$worktree_dir" clean -fd 2>/dev/null || true
    if err=$(git worktree remove --force "$worktree_dir" 2>&1); then
      echo "Successfully removed worktree after clean: $worktree_dir" >&2
    else
      echo "Warning: git worktree remove still failed: $err" >&2
      rm -rf "$worktree_dir"
      echo "Manually removed directory: $worktree_dir" >&2
    fi
  fi

  # Verify the directory is actually gone
  if [ -d "$worktree_dir" ]; then
    echo "Error: Directory still exists after cleanup, force removing: $worktree_dir" >&2
    rm -rf "$worktree_dir"
  fi

  # Clean up any dangling worktree references
  git worktree prune
else
  echo "No worktree directory found at: $worktree_dir" >&2
fi

# STEP 3: Kill the tmux session now that cleanup is done
if [ -n "$session_name" ] && tmux has-session -t "=$session_name" 2>/dev/null; then
  echo "Killing tmux session: $session_name" >&2

  if [ -n "${TMUX:-}" ]; then
    current_session=$(tmux display-message -p '#S')
    if [ "$current_session" = "$session_name" ]; then
      other_session=$(tmux list-sessions -F '#S' | grep -v "^$session_name$" | head -n 1)
      if [ -n "$other_session" ]; then
        tmux switch-client -t "=$other_session"
      else
        tmux new-session -d -s "main"
        tmux switch-client -t "=main"
      fi
    fi
  fi

  tmux kill-session -t "=$session_name"
fi

echo "Cleanup completed for: $worktree_dir" >&2
