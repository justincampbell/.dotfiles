#!/bin/bash
# Handle URLs by launching appropriate workflow
# Usage: handle-workflow-url <url>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Source shared utilities
source "$SCRIPT_DIR/../shared.sh"

url="$1"

if [ -z "$url" ]; then
    echo "Usage: $0 <url>" >&2
    exit 1
fi

# Determine which workflow to launch based on URL pattern
workflow_name=""

case "$url" in
    *app.shortcut.com/*/story/*)
        workflow_name="start-shortcut-story"
        ;;

    *github.com/notifications*)
        workflow_name="process-github-notifications"
        ;;

    *github.com/*/pull/*)
        workflow_name="review-github-pr"
        ;;

    *github.com/pulls*)
        workflow_name="review-github-prs"
        ;;

    *)
        echo "No workflow configured for URL: $url" >&2
        exit 1
        ;;
esac

# Determine tmux target for displaying popup
if [ -n "${TMUX:-}" ]; then
    popup_target=""
else
    active_session=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | head -n 1)
    if [ -z "$active_session" ]; then
        echo "Error: No active tmux session found" >&2
        exit 1
    fi
    popup_target="-t $active_session"
fi

# Workflows with a URL arg go through launch-workflow (sets up worktree, switches session)
# Others run directly
case "$workflow_name" in
    start-shortcut-story|review-github-pr)
        tmux display-popup $popup_target -E -w 80% -h 80% \
            "bash $SCRIPT_DIR/launch-workflow '$workflow_name' '$url'"
        ;;
    *)
        "$SCRIPT_DIR/start-workflow" "$workflow_name"
        ;;
esac
