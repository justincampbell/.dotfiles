#!/bin/bash
# Handle URLs by launching appropriate workflow
# Usage: handle-workflow-url <url>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Source shared utilities
source "$SCRIPT_DIR/../shared.sh"

url="$1"

if [ -z "$url" ]; then
    echo "Usage: $0 <url>" >&2
    exit 1
fi

# Determine which workflow to launch based on URL pattern
workflow_name=""

case "$url" in
    *app.shortcut.com/*/epic/*|*app.shortcut.com/*/objective/*)
        tmux display-popup -E -w 80% -h 80% \
            "bash $SCRIPT_DIR/start-planning '$url'"
        exit 0
        ;;

    *app.shortcut.com/*/story/*)
        workflow_name="start-shortcut-story"
        ;;

    *github.com/notifications*)
        workflow_name="process-github-notifications"
        ;;

    *github.com/*/issues/*)
        workflow_name="start-github-issue"
        ;;

    *app.datadoghq.com/error-tracking/issue/*)
        workflow_name="fix-datadog-error"
        ;;

    *github.com/*/pull/*)
        # Show mode selection menu — each item launches display-popup directly
        # (run-shell has no client context, so it can't open popups)
        tmux display-menu -T "PR Review" \
            "Review" r "display-popup -E -w 80% -h 80% \"bash $SCRIPT_DIR/launch-workflow review-github-pr '$url'\"" \
            "Review (auto-approve)" a "display-popup -E -w 80% -h 80% \"bash $SCRIPT_DIR/launch-workflow review-github-pr-auto-approve '$url'\"" \
            "Fix CI / address feedback" f "display-popup -E -w 80% -h 80% \"bash $SCRIPT_DIR/launch-workflow fix-github-pr '$url'\"" \
            "Just checkout" c "display-popup -E -w 80% -h 80% \"bash $SCRIPT_DIR/launch-workflow --no-prompt review-github-pr '$url'\""
        exit 0
        ;;

    *github.com/pulls*)
        workflow_name="review-github-prs"
        ;;

    *github.com/*/*)
        workflow_name="open-github-repo"
        ;;

    *)
        echo "No workflow configured for URL: $url" >&2
        exit 1
        ;;
esac

# Determine tmux target for displaying popup
if [ -n "${TMUX:-}" ]; then
    popup_target=()
else
    active_session=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | head -n 1)
    if [ -z "$active_session" ]; then
        echo "Error: No active tmux session found" >&2
        exit 1
    fi
    popup_target=(-t "$active_session")
fi

# Workflows with a URL arg go through launch-workflow (sets up worktree, switches session)
# Others run directly
case "$workflow_name" in
    start-shortcut-story|start-github-issue|review-github-pr|fix-datadog-error|open-github-repo)
        tmux display-popup "${popup_target[@]}" -E -w 80% -h 80% \
            "bash $SCRIPT_DIR/launch-workflow '$workflow_name' '$url'"
        ;;
    *)
        "$SCRIPT_DIR/start-workflow" "$workflow_name"
        ;;
esac
